<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Ad-hoc signatures have no Team ID, so hardened runtime otherwise
       rejects the separately signed PDFium dylib. Developer ID builds
       explicitly remove this entitlement in the release workflow. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
