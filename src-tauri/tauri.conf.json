{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lantern",
  "version": "2.0.5",
  "identifier": "com.klaragraff.lantern",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lantern",
        "width": 1440,
        "height": 960,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' blob:; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self' asset: http://asset.localhost data: blob:; connect-src 'self' asset: http://asset.localhost ipc: http://ipc.localhost http://localhost:1430 ws://localhost:1430; media-src 'self' asset: http://asset.localhost data: blob:; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'none'; frame-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["dmg", "app", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["epub"],
        "mimeType": "application/epub+zip",
        "description": "EPUB Ebook"
      },
      {
        "ext": ["pdf"],
        "mimeType": "application/pdf",
        "description": "PDF Document"
      },
      {
        "ext": ["txt"],
        "mimeType": "text/plain",
        "description": "Plain Text Document"
      },
      {
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown",
        "description": "Markdown Document"
      },
      {
        "ext": ["html", "htm"],
        "mimeType": "text/html",
        "description": "HTML Document"
      },
      {
        "ext": ["mobi", "azw", "azw3"],
        "mimeType": "application/x-mobipocket-ebook",
        "description": "MOBI Ebook"
      },
      {
        "ext": ["fb2", "fbz"],
        "mimeType": "application/x-fictionbook+xml",
        "description": "FictionBook Ebook"
      },
      {
        "ext": ["cbz"],
        "mimeType": "application/vnd.comicbook+zip",
        "description": "Comic Book Archive"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-",
      "entitlements": "Entitlements.adhoc.plist"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256"
    }
  }
}
